{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["vllm", "inference"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(vllm:num_requests_running, model_name)",
        "includeAll": true,
        "label": "Model",
        "multi": true,
        "name": "model",
        "options": [],
        "query": { "query": "label_values(vllm:num_requests_running, model_name)", "refId": "var" },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "vLLM Engine",
  "uid": "vllm-engine",
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Engine Up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "expr": "up{job=\"vllm\"}", "legendFormat": "{{instance}}", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Running Requests",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } } },
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "expr": "sum(vllm:num_requests_running{model_name=~\"$model\"})", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Waiting Requests",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 } ] } } },
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "expr": "sum(vllm:num_requests_waiting{model_name=~\"$model\"})", "refId": "A" } ]
    },
    {
      "type": "gauge",
      "title": "KV Cache Usage",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 0.75 }, { "color": "red", "value": 0.9 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [ { "expr": "max(vllm:kv_cache_usage_perc{model_name=~\"$model\"})", "refId": "A" } ]
    },

    {
      "type": "timeseries",
      "title": "Token Throughput (tokens/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } } },
      "targets": [
        { "expr": "sum(rate(vllm:prompt_tokens_total{model_name=~\"$model\"}[$__rate_interval]))", "legendFormat": "prompt", "refId": "A" },
        { "expr": "sum(rate(vllm:generation_tokens_total{model_name=~\"$model\"}[$__rate_interval]))", "legendFormat": "generation", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Concurrency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } } },
      "targets": [
        { "expr": "sum(vllm:num_requests_running{model_name=~\"$model\"})", "legendFormat": "running", "refId": "A" },
        { "expr": "sum(vllm:num_requests_waiting{model_name=~\"$model\"})", "legendFormat": "waiting", "refId": "B" }
      ]
    },

    {
      "type": "timeseries",
      "title": "Time To First Token (TTFT)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0, "showPoints": "never" } } },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.9, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p90", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Inter-Token Latency (TPOT)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0, "showPoints": "never" } } },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum by (le) (rate(vllm:inter_token_latency_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.9, sum by (le) (rate(vllm:inter_token_latency_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p90", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:inter_token_latency_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p99", "refId": "C" }
      ]
    },

    {
      "type": "timeseries",
      "title": "End-to-End Request Latency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0, "showPoints": "never" } } },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.9, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p90", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Queue Time (p90) & Request Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 0, "showPoints": "never" } }, "overrides": [ { "matcher": { "id": "byName", "options": "success/s" }, "properties": [ { "id": "unit", "value": "reqps" }, { "id": "custom.axisPlacement", "value": "right" } ] } ] },
      "targets": [
        { "expr": "histogram_quantile(0.9, sum by (le) (rate(vllm:request_queue_time_seconds_bucket{model_name=~\"$model\"}[$__rate_interval])))", "legendFormat": "queue p90 (s)", "refId": "A" },
        { "expr": "sum(rate(vllm:request_success_total{model_name=~\"$model\"}[$__rate_interval]))", "legendFormat": "success/s", "refId": "B" }
      ]
    },

    {
      "type": "timeseries",
      "title": "Prefix Cache Hit Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } } },
      "targets": [
        { "expr": "sum(rate(vllm:prefix_cache_hits_total{model_name=~\"$model\"}[$__rate_interval])) / clamp_min(sum(rate(vllm:prefix_cache_queries_total{model_name=~\"$model\"}[$__rate_interval])), 1)", "legendFormat": "hit rate", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Preemptions /s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } } },
      "targets": [
        { "expr": "sum(rate(vllm:num_preemptions_total{model_name=~\"$model\"}[$__rate_interval]))", "legendFormat": "preemptions", "refId": "A" }
      ]
    }
  ]
}
