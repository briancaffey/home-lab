{
  "title": "GPU Fleet \u2014 per-device utilization & VRAM by service",
  "uid": "gpu-fleet",
  "tags": [
    "gpu",
    "inference"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(vram_used_bytes, node)",
          "refId": "node"
        },
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 10,
      "type": "table",
      "title": "Active GPU processes \u2014 all machines",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 16,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "format": "table",
          "instant": true,
          "expr": "sum by (node, namespace, pod, process_name) (vram_used_bytes)"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "node": "Machine",
              "namespace": "Namespace",
              "pod": "Pod",
              "process_name": "Process",
              "Value": "VRAM"
            },
            "indexByName": {
              "node": 0,
              "namespace": 1,
              "pod": 2,
              "process_name": 3,
              "Value": 4
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": "",
            "sort": [
              {
                "field": "Machine"
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "VRAM"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              },
              {
                "id": "custom.align",
                "value": "right"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "gradient"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 8000000000.0
                    },
                    {
                      "color": "orange",
                      "value": 16000000000.0
                    },
                    {
                      "color": "red",
                      "value": 22000000000.0
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "sortBy": [
          {
            "displayName": "Machine"
          }
        ],
        "footer": {
          "show": false
        }
      },
      "description": "Every process holding GPU memory right now, by machine. Click a column header to re-sort (e.g. VRAM to see the biggest consumers)."
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "GPU utilization \u2014 now",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "instant": true,
          "expr": "gpu_util_percent",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "description": "Whole-device SM utilization per machine, current value."
    },
    {
      "id": 1,
      "type": "row",
      "title": "$node \u2014 detail",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "repeat": "node",
      "repeatDirection": "v",
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "VRAM by service \u2014 $node",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 16,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "expr": "sum by (namespace, pod) (vram_used_bytes{node=\"$node\"})",
          "legendFormat": "{{namespace}}/{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 45,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "showPoints": "never",
            "gradientMode": "opacity"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "description": "Per-pod GPU memory on this device, stacked. VRAM is the scarce/contended resource on shared GPUs (per-process compute % isn't exposed on GeForce/GB10)."
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "GPU utilization \u2014 $node",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "expr": "gpu_util_percent{node=\"$node\"}",
          "legendFormat": "GPU {{gpu}} SM %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never",
            "gradientMode": "scheme"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "description": "Whole-device SM utilization (from nvidia-smi). Read alongside the VRAM panel to see which resident service is driving the load."
    },
    {
      "id": 20,
      "type": "row",
      "collapsed": false,
      "title": "Temperatures \u2014 GPU \u00b7 SoC \u00b7 CPU \u00b7 NVMe",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 19
      },
      "panels": []
    },
    {
      "id": 21,
      "type": "gauge",
      "title": "GPU \u2014 a1 (4090)",
      "description": "dcgm-exporter core temp. 4090 throttles ~84\u00b0C.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 4,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 20,
          "max": 100,
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 83
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "minVizHeight": 75,
        "minVizWidth": 75,
        "sizing": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "DCGM_FI_DEV_GPU_TEMP{instance=~\"192\\\\.168\\\\.5\\\\.253.*\"}",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "type": "gauge",
      "title": "GPU \u2014 a3 (4090)",
      "description": "dcgm-exporter core temp. 4090 throttles ~84\u00b0C.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 4,
        "x": 4,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 20,
          "max": 100,
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 83
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "minVizHeight": 75,
        "minVizWidth": 75,
        "sizing": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "DCGM_FI_DEV_GPU_TEMP{instance=~\"192\\\\.168\\\\.5\\\\.173.*\"}",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },
    {
      "id": 23,
      "type": "gauge",
      "title": "spark \u2014 SoC (hottest zone)",
      "description": "Max of the GB10's acpitz thermal zones (unified SoC \u2014 CPU+GPU share the envelope). No per-GPU sensor: dcgm can't read GB10 and vram-reporter doesn't export temp (yet). This box wedged under acestep+vLLM memory pressure on 2026-07-01.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 4,
        "x": 8,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 20,
          "max": 100,
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "minVizHeight": 75,
        "minVizWidth": 75,
        "sizing": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max(node_thermal_zone_temp{instance=~\"192\\\\.168\\\\.6\\\\.19.*\"})",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ]
    },
    {
      "id": 24,
      "type": "bargauge",
      "title": "CPU package \u2014 per node",
      "description": "x86_pkg_temp per box. a2's 4090 has NO GPU temp source until its NVML/dcgm issue is fixed (or vram-reporter grows a temp gauge) \u2014 its CPU pkg + NVMe are the best proxies. x1 exposes no thermal sensors at all.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 12,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 20,
          "max": 100,
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "valueMode": "color",
        "namePlacement": "left"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "instant": true,
          "refId": "A",
          "expr": "label_replace(label_replace(label_replace(label_replace(label_replace(label_replace(node_thermal_zone_temp{type=\"x86_pkg_temp\"}, \"node\",\"a3\",\"instance\",\"192\\\\.168\\\\.5\\\\.173.*\"), \"node\",\"a1\",\"instance\",\"192\\\\.168\\\\.5\\\\.253.*\"), \"node\",\"a2\",\"instance\",\"192\\\\.168\\\\.5\\\\.96.*\"), \"node\",\"spark\",\"instance\",\"192\\\\.168\\\\.6\\\\.19.*\"), \"node\",\"x1\",\"instance\",\"192\\\\.168\\\\.5\\\\.174.*\"), \"node\",\"t430\",\"instance\",\"192\\\\.168\\\\.4\\\\.33.*\")",
          "legendFormat": "{{node}}"
        }
      ]
    },
    {
      "id": 25,
      "type": "bargauge",
      "title": "NVMe \u2014 per drive",
      "description": "node-exporter hwmon nvme composite temps (sensor temp1). Drives typically throttle ~70-80\u00b0C.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 18,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 20,
          "max": 90,
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "red",
                "value": 72
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "valueMode": "color",
        "namePlacement": "left"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "instant": true,
          "refId": "A",
          "expr": "label_replace(label_replace(label_replace(label_replace(label_replace(node_hwmon_temp_celsius{chip=~\"nvme.*\", sensor=\"temp1\"}, \"node\",\"a3\",\"instance\",\"192\\\\.168\\\\.5\\\\.173.*\"), \"node\",\"a1\",\"instance\",\"192\\\\.168\\\\.5\\\\.253.*\"), \"node\",\"a2\",\"instance\",\"192\\\\.168\\\\.5\\\\.96.*\"), \"node\",\"spark\",\"instance\",\"192\\\\.168\\\\.6\\\\.19.*\"), \"node\",\"x1\",\"instance\",\"192\\\\.168\\\\.5\\\\.174.*\")",
          "legendFormat": "{{node}} {{chip}}"
        }
      ]
    },
    {
      "id": 26,
      "type": "timeseries",
      "title": "Temperature history \u2014 all sensors",
      "description": "GPU core+mem (dcgm: a1/a3), spark SoC hottest zone, CPU package per node. Spikes here = the early-warning for another spark-style thermal wedge.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 20,
          "custom": {
