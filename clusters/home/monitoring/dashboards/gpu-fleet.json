          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "legendFormat": "{{node}} GPU",
          "expr": "label_replace(label_replace(label_replace(label_replace(label_replace(DCGM_FI_DEV_GPU_TEMP, \"node\",\"a3\",\"instance\",\"192\\\\.168\\\\.5\\\\.173.*\"), \"node\",\"a1\",\"instance\",\"192\\\\.168\\\\.5\\\\.253.*\"), \"node\",\"a2\",\"instance\",\"192\\\\.168\\\\.5\\\\.96.*\"), \"node\",\"spark\",\"instance\",\"192\\\\.168\\\\.6\\\\.19.*\"), \"node\",\"x1\",\"instance\",\"192\\\\.168\\\\.5\\\\.174.*\")"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "B",
          "legendFormat": "{{node}} GPU mem",
          "expr": "label_replace(label_replace(label_replace(label_replace(label_replace(DCGM_FI_DEV_MEMORY_TEMP, \"node\",\"a3\",\"instance\",\"192\\\\.168\\\\.5\\\\.173.*\"), \"node\",\"a1\",\"instance\",\"192\\\\.168\\\\.5\\\\.253.*\"), \"node\",\"a2\",\"instance\",\"192\\\\.168\\\\.5\\\\.96.*\"), \"node\",\"spark\",\"instance\",\"192\\\\.168\\\\.6\\\\.19.*\"), \"node\",\"x1\",\"instance\",\"192\\\\.168\\\\.5\\\\.174.*\")"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "C",
          "legendFormat": "spark SoC (max zone)",
          "expr": "max(node_thermal_zone_temp{instance=~\"192\\\\.168\\\\.6\\\\.19.*\"})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "D",
          "legendFormat": "{{node}} CPU pkg",
          "expr": "label_replace(label_replace(label_replace(label_replace(label_replace(label_replace(node_thermal_zone_temp{type=\"x86_pkg_temp\"}, \"node\",\"a3\",\"instance\",\"192\\\\.168\\\\.5\\\\.173.*\"), \"node\",\"a1\",\"instance\",\"192\\\\.168\\\\.5\\\\.253.*\"), \"node\",\"a2\",\"instance\",\"192\\\\.168\\\\.5\\\\.96.*\"), \"node\",\"spark\",\"instance\",\"192\\\\.168\\\\.6\\\\.19.*\"), \"node\",\"x1\",\"instance\",\"192\\\\.168\\\\.5\\\\.174.*\"), \"node\",\"t430\",\"instance\",\"192\\\\.168\\\\.4\\\\.33.*\")"
        }
      ]
    }
  ]
