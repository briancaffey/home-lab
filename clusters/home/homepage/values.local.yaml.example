# Template for the gitignored values.local.yaml. Copy it, replace the tailnet
# suffix (find it with `tailscale status` — the *.ts.net part), then apply with:
#
#   cp values.local.yaml.example values.local.yaml
#   # edit the <your-tailnet> placeholders
#   helm upgrade homepage homepage \
#     --repo https://jameswynn.github.io/helm-charts --version 2.1.0 -n homepage \
#     -f values.yaml -f values.local.yaml
#
# Keeps the tailnet name out of the public repo. Helm REPLACES list-valued keys,
# so restate the whole `env` list, and list every Tailnet tile you want.
env:
  - name: HOMEPAGE_ALLOWED_HOSTS
    value: "home.lan,homepage.<your-tailnet>.ts.net"

config:
  services:
    - Tailnet:
        - Grafana:
            href: https://grafana.<your-tailnet>.ts.net
            icon: grafana.png
            description: Metrics & dashboards
        # …one entry per service exposed via the Tailscale operator
