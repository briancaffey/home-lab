# Never commit secrets to this GitOps repo — create them in-cluster instead.
*.env
.env*
*.key
*.pem
*.crt
*.p12
*.pfx
id_rsa*
*kubeconfig*
kubeconfig
*.tfstate
*.tfstate.*
secret*.yaml
secrets*.yaml
*-secret.yaml
*.secret.yaml
# EXCEPTION: ESO ExternalSecret manifests are value-less pointers (they reference
# Vaultwarden items, never contain secret data), so they're safe despite the
# "-secret" in many names. This dir must ONLY ever hold ExternalSecrets.
!clusters/home/external-secrets/secrets/*.yaml

# kustomize `--enable-helm` pulls charts here on build; re-pulled each time,
# so we don't vendor them.
charts/

# Local-only overrides for environment-specific (non-secret but private) values
# — e.g. the tailnet MagicDNS suffix. Committed counterpart: *.local.yaml.example
*.local.yaml

# macOS cruft
.DS_Store
